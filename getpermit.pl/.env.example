# =============================================================================
# .env.example — skopiuj do .env (Prisma + serwer) i .env.local (Next.js)
# =============================================================================

# --- Email (Resend) ----------------------------------------------------------
# https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL_TO=kontakt@getpermit.pl
CONTACT_EMAIL_FROM=noreply@getpermit.pl

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://getpermit.pl

# --- Supabase ----------------------------------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
# Service-role key — NIGDY do client bundle. Tylko server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# --- Vercel Cron -------------------------------------------------------------
# Bearer token sprawdzany przez /api/cron/* endpointy. Vercel Cron automatycznie
# wysyła ten nagłówek dla zaplanowanych jobów. Wygeneruj długi losowy ciąg.
CRON_SECRET=replace-with-long-random-string

# --- Prisma / Postgres -------------------------------------------------------
# Project Settings → Database → Connection string
# DATABASE_URL: pooler (Transaction mode, port 6543) — używa app w runtime.
# DIRECT_URL: bezpośredni (Session mode, port 5432) — używa Prisma do migracji.
# UWAGA: te dwie zmienne MUSZĄ być w .env (nie .env.local), bo Prisma CLI
# czyta tylko .env. Plik .env jest gitignored.
DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
