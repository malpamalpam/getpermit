// Prisma schema dla panelu klienta getpermit.pl
//
// Założenia:
// - Postgres uruchomiony w Supabase EU (Frankfurt)
// - User.id jest UUID-em zsynchronizowanym z auth.users.id (Supabase Auth)
// - Schema = public; nie tworzymy FK do auth.users (osobna schema), tylko
//   zapewniamy spójność po stronie aplikacji (przy callback po magic linku)
// - RLS jest dodawane osobnym SQL-em (prisma/manual_rls.sql) — Prisma migracje
//   nie zarządzają politykami bezpieczeństwa RLS automatycznie

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// ENUMY
// =============================================================================

enum Role {
  CLIENT
  STAFF
  ADMIN
}

enum CaseType {
  TEMPORARY_RESIDENCE
  PERMANENT_RESIDENCE
  WORK_PERMIT_A
  WORK_PERMIT_B
  BLUE_CARD
  CITIZENSHIP
  INVITATION
  OTHER
}

enum CaseStatus {
  SUBMITTED
  IN_PROGRESS
  SUPPLEMENT_REQUIRED
  DECISION_POSITIVE
  DECISION_NEGATIVE
  APPEAL
}

enum EventType {
  APPLICATION_SUBMITTED
  OFFICE_CONFIRMATION
  SUPPLEMENT_REQUEST
  SUPPLEMENT_SENT
  DECISION
  APPEAL
  OTHER
}

enum DocumentType {
  PASSPORT
  RESIDENCE_CARD
  DIPLOMA
  WORK_CERTIFICATE
  EMPLOYMENT_CONTRACT
  REGISTRATION_CERTIFICATE
  MARRIAGE_CERTIFICATE
  BIRTH_CERTIFICATE
  RESIDENCE_PROOF
  HEALTH_INSURANCE
  BIOMETRIC_PHOTO
  OTHER
}

enum VerificationStatus {
  PENDING
  VERIFIED
  NEEDS_CORRECTION
}

enum AccessAction {
  VIEW_CASE
  VIEW_DOCUMENT
  DOWNLOAD_DOCUMENT
  CREATE_CASE
  UPDATE_CASE
  CREATE_EVENT
  UPLOAD_DOCUMENT
  UPLOAD_CLIENT_DOCUMENT
  DELETE_CLIENT_DOCUMENT
  VERIFY_DOCUMENT
  SEND_MESSAGE
}

// =============================================================================
// MODELE
// =============================================================================

model User {
  id          String    @id @db.Uuid
  email       String    @unique
  role        Role      @default(CLIENT)
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  phone       String?
  locale      String    @default("pl")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  // sprawy klienta
  cases Case[] @relation("ClientCases")
  // sprawy przypisane jako opiekun (staff)
  assignedCases Case[] @relation("AssignedStaff")
  // utworzone eventy (staff)
  createdEvents CaseEvent[] @relation("EventCreator")
  // uploadowane dokumenty (staff)
  uploadedDocuments Document[] @relation("DocumentUploader")
  // uploadowane dokumenty (klient)
  uploadedClientDocuments Document[] @relation("ClientDocumentUploader")
  // wysłane wiadomości
  sentMessages Message[] @relation("MessageSender")
  // logi dostępu
  accessLogs AccessLog[]
  // dane osobowe (ankieta)
  personalData PersonalData?

  @@index([role])
  @@map("users")
}

model Case {
  id                  String     @id @default(uuid()) @db.Uuid
  userId              String     @map("user_id") @db.Uuid
  type                CaseType
  status              CaseStatus @default(SUBMITTED)
  title               String
  description         String?
  submittedAt         DateTime?  @map("submitted_at")
  expectedDecisionAt  DateTime?  @map("expected_decision_at")
  assignedStaffId     String?    @map("assigned_staff_id") @db.Uuid
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  user          User        @relation("ClientCases", fields: [userId], references: [id], onDelete: Cascade)
  assignedStaff User?       @relation("AssignedStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  events        CaseEvent[]
  documents     Document[]
  messages      Message[]
  accessLogs    AccessLog[]

  @@index([userId])
  @@index([status])
  @@index([assignedStaffId])
  @@map("cases")
}

model CaseEvent {
  id                String    @id @default(uuid()) @db.Uuid
  caseId            String    @map("case_id") @db.Uuid
  eventType         EventType @map("event_type")
  title             String
  description       String?
  eventDate         DateTime  @map("event_date")
  createdByStaffId  String?   @map("created_by_staff_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")

  case             Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdByStaff   User? @relation("EventCreator", fields: [createdByStaffId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([eventDate])
  @@map("case_events")
}

model Document {
  id                  String              @id @default(uuid()) @db.Uuid
  caseId              String              @map("case_id") @db.Uuid
  fileName            String              @map("file_name")
  /// Ścieżka w Supabase Storage (bucket: case-documents)
  storagePath         String              @map("storage_path")
  fileSize            Int                 @map("file_size")
  mimeType            String              @map("mime_type")
  description         String?
  documentType        DocumentType?       @map("document_type")
  uploadedByStaffId   String?             @map("uploaded_by_staff_id") @db.Uuid
  uploadedByUserId    String?             @map("uploaded_by_user_id") @db.Uuid
  verificationStatus  VerificationStatus? @map("verification_status")
  uploadedAt          DateTime            @default(now()) @map("uploaded_at")

  case             Case  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedByStaff  User? @relation("DocumentUploader", fields: [uploadedByStaffId], references: [id], onDelete: SetNull)
  uploadedByUser   User? @relation("ClientDocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@map("documents")
}

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  caseId    String   @map("case_id") @db.Uuid
  senderId  String   @map("sender_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  case   Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sender User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@map("messages")
}

model AccessLog {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String?      @map("user_id") @db.Uuid
  caseId    String?      @map("case_id") @db.Uuid
  action    AccessAction
  ipAddress String?      @map("ip_address")
  userAgent String?      @map("user_agent")
  metadata  Json?
  timestamp DateTime     @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  case Case? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([caseId, timestamp])
  @@index([userId, timestamp])
  @@map("access_logs")
}

// =============================================================================
// DANE OSOBOWE (ANKIETA)
// =============================================================================

model PersonalData {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  // --- Zdjęcie biometryczne (base64 data URL) ---
  biometricPhoto String? @map("biometric_photo") @db.Text

  // --- Sekcja A: Dane podstawowe ---
  firstNameLatin   String?   @map("first_name_latin")
  lastNameLatin    String?   @map("last_name_latin")
  nativeFullName   String?   @map("native_full_name")
  previousName     String?   @map("previous_name")
  gender           String?
  dateOfBirth      DateTime? @map("date_of_birth")
  placeOfBirth     String?   @map("place_of_birth")
  countryOfBirth   String?   @map("country_of_birth")
  citizenship      String?
  secondCitizenship String?  @map("second_citizenship")
  nationality      String?
  maritalStatus    String?   @map("marital_status")
  education        String?
  height           Int?
  eyeColor         String?   @map("eye_color")
  specialFeatures  String?   @map("special_features") @db.Text
  fatherName       String?   @map("father_name")
  motherName       String?   @map("mother_name")
  motherMaidenName String?   @map("mother_maiden_name")

  // --- Sekcja B: Dokument tożsamości i paszport ---
  passportNumber          String?   @map("passport_number")
  passportSeries          String?   @map("passport_series")
  passportIssueDate       DateTime? @map("passport_issue_date")
  passportExpiryDate      DateTime? @map("passport_expiry_date")
  passportIssuingAuthority String?  @map("passport_issuing_authority")
  pesel                   String?
  residenceCardNumber     String?   @map("residence_card_number")
  residenceCardExpiry     DateTime? @map("residence_card_expiry")
  visaNumber              String?   @map("visa_number")
  visaType                String?   @map("visa_type")
  visaExpiry              DateTime? @map("visa_expiry")

  // --- Sekcja C: Adres zamieszkania w Polsce ---
  street                String?
  houseNumber           String?   @map("house_number")
  apartmentNumber       String?   @map("apartment_number")
  postalCode            String?   @map("postal_code")
  city                  String?
  voivodeship           String?
  registrationAddress   String?   @map("registration_address")
  correspondenceAddress String?   @map("correspondence_address")

  // --- Sekcja D: Dane kontaktowe ---
  phoneNumber       String?  @map("phone_number")
  contactEmail      String?  @map("contact_email")
  additionalPhone   String?  @map("additional_phone")
  preferredLanguage String?  @map("preferred_language")

  // --- Sekcja E: Informacje o pobycie w Polsce ---
  firstEntryDate          DateTime? @map("first_entry_date")
  lastEntryDate           DateTime? @map("last_entry_date")
  purposeOfStay           String?   @map("purpose_of_stay")
  currentResidenceTitle   String?   @map("current_residence_title")
  pendingProceedings      Boolean?  @map("pending_proceedings")
  caseNumberAtOffice      String?   @map("case_number_at_office")
  handlingOffice          String?   @map("handling_office")
  criminalRecord          Boolean?  @map("criminal_record")
  deportationProceedings  Boolean?  @map("deportation_proceedings")
  plannedStayDuration     String?   @map("planned_stay_duration")
  occupation              String?   /// Zawód/stanowisko (kod KZIS + nazwa)

  // --- Sekcja F: Dane pracodawcy ---
  employerName            String?   @map("employer_name")
  employerStreet          String?   @map("employer_street")
  employerHouseNumber     String?   @map("employer_house_number")
  employerApartmentNumber String?   @map("employer_apartment_number")
  employerPostalCode      String?   @map("employer_postal_code")
  employerCity            String?   @map("employer_city")
  employerPhone           String?   @map("employer_phone")
  employerEmail           String?   @map("employer_email")
  contractType            String?   @map("contract_type") /// EMPLOYMENT, MANDATE, SPECIFIC_TASK, MANAGERIAL
  contractFrom            DateTime? @map("contract_from")
  contractTo              DateTime? @map("contract_to") /// null = czas nieokreślony
  contractIndefinite      Boolean?  @map("contract_indefinite")
  salary                  String?   /// kwota wynagrodzenia

  // --- Sekcja G: Historia pobytu i dane dodatkowe ---
  familyMembersInPoland   String? @map("family_members_in_poland") @db.Text
  lastEntryDetails        String? @map("last_entry_details") @db.Text
  previousVisitsPoland    String? @map("previous_visits_poland") @db.Text
  travelsOutsidePoland    String? @map("travels_outside_poland") @db.Text
  addressCountryOfOrigin  String? @map("address_country_of_origin") @db.Text
  previousAddressesPoland String? @map("previous_addresses_poland") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personal_data")
}

model FdkPermit {
  id              Int      @id @default(autoincrement())
  nazwisko        String
  imie            String
  typDokumentu    String   @map("typ_dokumentu") /// ZEZWOLENIE, OSWIADCZENIE, BLUE_CARD
  dataOd          DateTime? @map("data_od")
  dataDo          DateTime? @map("data_do")
  decyzjaOdebrana DateTime? @map("decyzja_odebrana")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([typDokumentu])
  @@index([dataDo])
  @@index([nazwisko])
  @@map("fdk_permits")
}

// =============================================================================
// MODUŁ FDK — KARTOTEKA CUDZOZIEMCÓW
// =============================================================================

enum FdkBaseType {
  ZEZWOLENIE
  OSWIADCZENIE
  KARTA_POBYTU
  BLUE_CARD
  ZGLOSZENIE_UA
}

enum FdkStatus {
  AKTYWNE
  WYGASLE
  UCHYLONE
  UMORZONE
  ZAKONCZONE
  W_TRAKCIE
  BRAK_DANYCH
}

model FdkForeigner {
  id              Int       @id @default(autoincrement())
  nazwisko        String
  imie            String?
  dataUrodzenia   DateTime? @map("data_urodzenia")
  miejsceUrodzenia String?  @map("miejsce_urodzenia")
  obywatelstwo    String?
  plec            String?
  pesel           String?
  nrPaszportu     String?   @map("nr_paszportu")
  paszportWaznyOd DateTime? @map("paszport_wazny_od")
  paszportWaznyDo DateTime? @map("paszport_wazny_do")
  adresPl         String?   @map("adres_pl") @db.Text
  telefon         String?
  email           String?
  nrKonta         String?   @map("nr_konta")
  uwagi           String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employmentBases    FdkEmploymentBase[]
  hrContracts        FdkHrContract[]
  detailedDocuments  FdkDetailedDocument[]
  attachments        FdkAttachment[]

  @@index([nazwisko])
  @@index([pesel])
  @@map("fdk_foreigners")
}

model FdkEmploymentBase {
  id            Int         @id @default(autoincrement())
  foreignerId   Int         @map("foreigner_id")
  typ           FdkBaseType
  status        FdkStatus   @default(BRAK_DANYCH)

  // Wspólne
  rodzajUmowy   String?     @map("rodzaj_umowy")
  dataOd        DateTime?   @map("data_od")
  dataDo        DateTime?   @map("data_do")

  // Zezwolenie
  firma              String?
  nrDecyzji          String?  @map("nr_decyzji")
  wezwanieBraki      String?  @map("wezwanie_braki") @db.Text
  powiadomienieDo    DateTime? @map("powiadomienie_do")
  uchylenie          String?  @db.Text
  startInfo          String?  @map("start_info") @db.Text

  // Oświadczenie
  nrOswiadczenia     String?  @map("nr_oswiadczenia")
  podjeciePracy      String?  @map("podjecie_pracy")

  // Karta pobytu
  urzad              String?
  rodzajSprawy       String?  @map("rodzaj_sprawy")
  dataZlozenia       DateTime? @map("data_zlozenia")
  sposobWysylki      String?  @map("sposob_wysylki")
  sygnatura          String?
  brakujaceDokumenty String?  @map("brakujace_dokumenty") @db.Text
  uwagiKp            String?  @map("uwagi_kp") @db.Text

  // Blue Card
  decyzjaOdebrana    DateTime? @map("decyzja_odebrana")
  stanowisko         String?   @db.Text
  stawka             Decimal?  @db.Decimal(12, 2)

  // Zgłoszenie UA
  dataPodjecia       DateTime? @map("data_podjecia")
  uwagiUa            String?   @map("uwagi_ua") @db.Text

  uwagi              String?   @db.Text
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  foreigner FdkForeigner @relation(fields: [foreignerId], references: [id], onDelete: Cascade)

  @@index([foreignerId])
  @@index([typ])
  @@index([status])
  @@index([dataDo])
  @@map("fdk_employment_bases")
}

model FdkHrContract {
  id            Int       @id @default(autoincrement())
  foreignerId   Int       @map("foreigner_id")
  rok           Int
  dataOd        DateTime? @map("data_od")
  dataDo        DateTime? @map("data_do")
  rodzajUmowy   String?   @map("rodzaj_umowy")
  kup           Decimal?  @db.Decimal(3, 2)
  kwotaBruttoMin Decimal? @map("kwota_brutto_min") @db.Decimal(12, 2)
  kwotaCalosciowa Decimal? @map("kwota_calosciowa") @db.Decimal(12, 2)
  stanowisko    String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  foreigner      FdkForeigner        @relation(fields: [foreignerId], references: [id], onDelete: Cascade)
  monthlyEntries FdkHrMonthlyEntry[]

  @@index([foreignerId])
  @@map("fdk_hr_contracts")
}

model FdkHrMonthlyEntry {
  id                    Int       @id @default(autoincrement())
  contractId            Int       @map("contract_id")
  miesiac               DateTime  /// Pierwszy dzień miesiąca
  umowaWystawiona       Boolean   @default(false) @map("umowa_wystawiona")
  rachunekWystawiony    Boolean   @default(false) @map("rachunek_wystawiony")
  pitWyslany            Boolean   @default(false) @map("pit_wyslany")
  kwota                 Decimal?  @db.Decimal(12, 2)
  komentarz             String?   @db.Text
  przekazaneDoPodpisu   Boolean   @default(false) @map("przekazane_do_podpisu")

  createdAt DateTime @default(now()) @map("created_at")

  contract FdkHrContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("fdk_hr_monthly_entries")
}

model FdkDetailedDocument {
  id            Int      @id @default(autoincrement())
  foreignerId   Int      @map("foreigner_id")
  typDokumentu  String   @map("typ_dokumentu") /// zezwolenie_na_prace, informacja_starosty, trc, pit, zus, ubezpieczenie, wyksztalcenie, pelnomocnictwo, oplata
  dane          Json     @default("{}") /// Elastyczny JSON z danymi per dokument
  createdAt     DateTime @default(now()) @map("created_at")

  foreigner FdkForeigner @relation(fields: [foreignerId], references: [id], onDelete: Cascade)

  @@index([foreignerId])
  @@index([typDokumentu])
  @@map("fdk_detailed_documents")
}

model FdkAttachment {
  id                Int      @id @default(autoincrement())
  foreignerId       Int      @map("foreigner_id")
  kategoria         String   /// glowne, wp_2023, wp_2024, trc_2024
  nazwaWyswietlana  String   @map("nazwa_wyswietlana")
  nazwaPliku        String   @map("nazwa_pliku")
  opis              String?  @db.Text
  typPliku          String   @map("typ_pliku") /// pdf, jpeg, png, docx
  storagePath       String   @map("storage_path")
  rozmiarBytes      BigInt?  @map("rozmiar_bytes")
  uploadedAt        DateTime @default(now()) @map("uploaded_at")

  foreigner FdkForeigner @relation(fields: [foreignerId], references: [id], onDelete: Cascade)

  @@index([foreignerId])
  @@index([kategoria])
  @@map("fdk_attachments")
}
