  "process": {
    "label": "\u042f\u043a \u043c\u0438 \u043f\u0440\u0430\u0446\u044e\u0454\u043c\u043e",
    "title": "3 \u043f\u0440\u043e\u0441\u0442\u0456 \u043a\u0440\u043e\u043a\u0438",
    "subtitle": "\u041a\u043e\u0436\u043d\u0443 \u0441\u043f\u0440\u0430\u0432\u0443 \u043c\u0438 \u0440\u043e\u0437\u0433\u043b\u044f\u0434\u0430\u0454\u043c\u043e \u0456\u043d\u0434\u0438\u0432\u0456\u0434\u0443\u0430\u043b\u044c\u043d\u043e, \u043f\u0440\u043e\u043f\u043e\u043d\u0443\u044e\u0447\u0438 \u043f\u0456\u0434\u0445\u043e\u0434\u044f\u0449\u0456 \u0440\u0456\u0448\u0435\u043d\u043d\u044f.",
    "step1": { "title": "\u0411\u0435\u0437\u043a\u043e\u0448\u0442\u043e\u0432\u043d\u0430 \u043a\u043e\u043d\u0441\u0443\u043b\u044c\u0442\u0430\u0446\u0456\u044f", "desc": "\u0420\u043e\u0437\u043a\u0430\u0436\u0456\u0442\u044c \u043f\u0440\u043e \u0441\u0432\u043e\u044e \u0441\u0438\u0442\u0443\u0430\u0446\u0456\u044e \u2014 \u043d\u0430\u0448\u0456 \u0435\u043a\u0441\u043f\u0435\u0440\u0442\u0438 \u043e\u0446\u0456\u043d\u044f\u0442\u044c \u0441\u043f\u0440\u0430\u0432\u0443 \u0442\u0430 \u0437\u0430\u043f\u0440\u043e\u043f\u043e\u043d\u0443\u044e\u0442\u044c \u043e\u043f\u0442\u0438\u043c\u0430\u043b\u044c\u043d\u0443 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0456\u044e." },
    "step2": { "title": "\u041f\u0456\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430 \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0456\u0432", "desc": "\u041f\u0456\u0434\u043f\u0438\u0441\u0430\u043d\u043d\u044f \u0434\u043e\u0433\u043e\u0432\u043e\u0440\u0443, \u0437\u0431\u0456\u0440 \u0442\u0430 \u043f\u0456\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430 \u0432\u0441\u0456\u0445 \u043d\u0435\u043e\u0431\u0445\u0456\u0434\u043d\u0438\u0445 \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0456\u0432." },
    "step3": { "title": "\u041f\u043e\u0437\u0438\u0442\u0438\u0432\u043d\u0435 \u0440\u0456\u0448\u0435\u043d\u043d\u044f", "desc": "\u041c\u0438 \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u044f\u0454\u043c\u043e \u0432\u0430\u0441 \u043f\u0435\u0440\u0435\u0434 \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043e\u044e \u0434\u043e \u043e\u0442\u0440\u0438\u043c\u0430\u043d\u043d\u044f \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0456\u0432, \u0449\u043e \u043f\u0456\u0434\u0442\u0432\u0435\u0440\u0434\u0436\u0443\u044e\u0442\u044c \u0432\u0430\u0448 \u0441\u0442\u0430\u0442\u0443\u0441." }
