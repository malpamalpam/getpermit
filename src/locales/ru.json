  "process": {
    "label": "\u041a\u0430\u043a \u043c\u044b \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u043c",
    "title": "3 \u043f\u0440\u043e\u0441\u0442\u044b\u0445 \u0448\u0430\u0433\u0430",
    "subtitle": "\u041a\u0430\u0436\u0434\u044b\u0439 \u0441\u043b\u0443\u0447\u0430\u0439 \u043c\u044b \u0440\u0430\u0441\u0441\u043c\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u043c \u0438\u043d\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043b\u044c\u043d\u043e, \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u044f \u043f\u043e\u0434\u0445\u043e\u0434\u044f\u0449\u0438\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u044f.",
    "step1": { "title": "\u0411\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u0430\u044f \u043a\u043e\u043d\u0441\u0443\u043b\u044c\u0442\u0430\u0446\u0438\u044f (\u043e\u043a. 15 \u043c\u0438\u043d)", "desc": "\u0420\u0430\u0441\u0441\u043a\u0430\u0436\u0438\u0442\u0435 \u043e \u0441\u0432\u043e\u0435\u0439 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438 \u2014 \u043d\u0430\u0448\u0438 \u044d\u043a\u0441\u043f\u0435\u0440\u0442\u044b \u043e\u0446\u0435\u043d\u044f\u0442 \u0434\u0435\u043b\u043e \u0438 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0430\u0442 \u043e\u043f\u0442\u0438\u043c\u0430\u043b\u044c\u043d\u0443\u044e \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044e." },
    "step2": { "title": "\u041f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430 \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u043e\u0432", "desc": "\u041f\u043e\u0434\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u0434\u043e\u0433\u043e\u0432\u043e\u0440\u0430, \u0441\u0431\u043e\u0440 \u0438 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430 \u0432\u0441\u0435\u0445 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u044b\u0445 \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u043e\u0432." },
    "step3": { "title": "\u041f\u043e\u043b\u043e\u0436\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u0435", "desc": "\u041c\u044b \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u043c \u0432\u0430\u0441 \u043f\u0435\u0440\u0435\u0434 \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u0435\u043c \u0434\u043e \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u0438\u044f \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u043e\u0432, \u043f\u043e\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044e\u0449\u0438\u0445 \u0432\u0430\u0448 \u0441\u0442\u0430\u0442\u0443\u0441." }
  },
  "faq": {
    "title": "Часто задаваемые вопросы",
    "subtitle": "Отвечаем на вопросы, которые слышим чаще всего от наших клиентов.",
    "items": {
      "cost": { "q": "Сколько стоит помощь в получении карты побыта?", "a": "Стоимость зависит от типа дела и его сложности. Бесплатная консультация позволит точно оценить ваше дело. Свяжитесь с нами — получите расчёт в течение 24 часов." },
      "duration": { "q": "Сколько длится процесс получения карты побыта?", "a": "Срок ожидания зависит от индивидуального дела и загруженности учреждения. Благодаря правильно подготовленной документации часто удаётся сократить этот срок." },
      "documents": { "q": "Какие документы нужно подготовить?", "a": "Список документов зависит от типа разрешения. На бесплатной консультации мы представим точный список — не волнуйтесь, ведём вас шаг за шагом." },
      "workWhileWaiting": { "q": "Можно ли работать в Польше, ожидая решения?", "a": "В большинстве случаев — да. После подачи полного заявления вы получаете штамп в паспорте, позволяющий легально работать до вынесения решения." },
      "worldwide": { "q": "Помогаете ли вы людям со всего мира?", "a": "Да, мы помогаем гражданам всех стран за пределами ЕС. Обслуживаем клиентов на польском, английском, русском и украинском языках." },
      "rejected": { "q": "Что если мой запрос будет отклонён?", "a": "Мы готовим апелляции на негативные решения и жалобы в случае задержек. 98% наших дел заканчиваются положительным решением." }
    }
  },
